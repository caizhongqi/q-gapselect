      {
        "baseline_id": "miqae_per_arm_sort",
        "bound_status": "symbolic_template_only",
        "category": "complete_topk_baseline",
        "display_name": "MIQAE per-arm estimate-then-sort",
        "fidelity_status": "known_nonfaithful",
        "implementation_status": "analytic_proxy_only",
        "interface_assumptions": [
          "B_theta can be index-fixed to a charged per-arm state-preparation oracle",
          "failure probability is allocated across all arms and adaptive rounds",
          "the strict boundary is discovered rather than supplied"
        ],
        "interface_status": "requires_charged_reduction",
        "oracle_model": "Single-amplitude state-preparation oracle A, Grover iterate powers, and measurements; one independent instance is compiled for each indexed arm.",
        "output_relation": "Simultaneous confidence intervals for every arm, followed by exact Top-k sorting only when the kth and (k+1)th intervals are disjoint.",
        "primary_eligibility": "eligible_primary",
        "primary_eligibility_reason": "It can return the complete exact Top-k set after a blind, charged per-arm compilation.",
        "query_bound_template": "sum_i Q_MIQAE(epsilon_i, delta_i), with every Grover power charged and sum_i delta_i <= delta; instantiate epsilon_i until the Top-k boundary certifies",
        "required_compilation_charges": [
          "indexed_to_per_arm_oracle",
          "grover_iterate_forward_calls",
          "grover_iterate_inverse_calls",
          "adaptive_round_measurements",
          "summable_confidence_allocation",
          "classical_sort_and_boundary_certificate"
        ],
        "source": {
          "source_key": "fukuzawa_ho_irani_zion_miqae",
          "source_kind": "arxiv_primary",
          "theorem_locator": "Main MIQAE correctness and query-complexity theorem in the cited version",
          "title": "Modified Iterative Quantum Amplitude Estimation is Asymptotically Optimal",
          "url": "https://arxiv.org/abs/2208.14612v4",
          "version_locator": "arXiv:2208.14612v4"
        }
      },
      {
        "baseline_id": "rall_coherent_ae_rounding",
        "bound_status": "symbolic_template_only",
        "category": "coherent_estimation_component",
        "display_name": "Rall coherent amplitude estimation with rounding promise",
        "fidelity_status": "not_audited",
        "implementation_status": "not_implemented",
        "interface_assumptions": [
          "all supported phases satisfy the declared rounding promise",
          "controlled oracle powers and inverse calls are available",
          "garbage and phase errors are included in the composition analysis"
        ],
        "interface_status": "requires_charged_reduction",
        "oracle_model": "Controlled eigenphase/amplitude unitary and inverse under an explicit finite-bit rounding promise, with diamond-norm error control.",
        "output_relation": "Coherently write rounded amplitude or phase bits; a separate legal selection composition must convert them to complete exact Top-k output.",
        "primary_eligibility": "composition_component",
        "primary_eligibility_reason": "It is a mandatory coherent-estimation threat but does not by itself return a Top-k set.",
